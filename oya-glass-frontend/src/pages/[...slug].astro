---
// Egen fil for å kunne opprette dynamiske ruter, basert på input fra Sanity.
// Dynamiske sider: Category, Series og Work.
// Koden i denne filen er tilpasset en hybridmodell:
// - Category = kategori-side
// - Series = serie med innebygde verk i works[]
// - Work = enkeltstående verk

import groq from "groq";
import { sanity } from "../lib/sanityClient";

import CategoryTemplate from "../templates/CategoryTemplate.astro";
import SeriesTemplate from "../templates/SeriesTemplate.astro";
import WorkTemplate from "../templates/WorkTemplate.astro";

/** --------
 * getStaticPaths
 * -------- */
export async function getStaticPaths() {
  const query = groq`
  {
    "categories": *[_type == "category" && defined(slug.current)]{
      "category": slug.current
    },

    "series": *[
      _type == "series" &&
      defined(slug.current) &&
      defined(category->slug.current)
    ]{
      "category": category->slug.current,
      "series": slug.current
    },

    "works": *[
      _type == "work" &&
      defined(slug.current) &&
      defined(category->slug.current)
    ]{
      "category": category->slug.current,
      "work": slug.current
    }
  }`;

  const routeData = await sanity.fetch(query);

  const categoryPaths = (routeData?.categories ?? [])
    .map((c: any) => c?.category)
    .filter((value: any) => typeof value === "string" && value.length > 0)
    .map((category: string) => ({
      params: { slug: category },
    }));

  const seriesPaths = (routeData?.series ?? [])
    .map((s: any) => ({
      category: s?.category,
      series: s?.series,
    }))
    .filter(
      (s: any) =>
        typeof s.category === "string" &&
        s.category.length > 0 &&
        typeof s.series === "string" &&
        s.series.length > 0
    )
    .map((s: any) => ({
      params: { slug: `${s.category}/${s.series}` },
    }));

  const workPaths = (routeData?.works ?? [])
    .map((w: any) => ({
      category: w?.category,
      work: w?.work,
    }))
    .filter(
      (w: any) =>
        typeof w.category === "string" &&
        w.category.length > 0 &&
        typeof w.work === "string" &&
        w.work.length > 0
    )
    .map((w: any) => ({
      params: { slug: `${w.category}/${w.work}` },
    }));

  return [...categoryPaths, ...seriesPaths, ...workPaths];
}

const slugStr = Astro.params.slug;
const segments = typeof slugStr === "string" ? slugStr.split("/") : [];

/** --------
 * Runtime: finn side basert på segments
 * -------- */

const len = segments.length;
const [categorySlug, second] = segments;

let pageType: "category" | "series" | "work" | null = null;
let data: any = null;

// /{category}
if (len === 1) {
  pageType = "category";
  data = await sanity.fetch(
    groq`
    *[_type == "category" && slug.current == $category][0]{
      _id,
      title,
      "slug": slug.current,
      description,
      coverImage,

      "series": *[
        _type == "series" &&
        category._ref == ^._id
      ] | order(coalesce(year, 0) desc, title asc){
        _id,
        title,
        "slug": slug.current,
        year,
        "image": coalesce(
          coverImage,
          works[0].image
        )
      },

      "works": *[
        _type == "work" &&
        category._ref == ^._id
      ] | order(coalesce(year, 0) desc, _createdAt desc){
        _id,
        title,
        "slug": slug.current,
        year,
        medium,
        dimensions,
        image{
          ...,
          alt
        }
      }
    }`,
    { category: categorySlug }
  );
}

// /{category}/{series} eller /{category}/{work}
else if (len === 2) {
  // Prøv SERIES først
  const seriesData = await sanity.fetch(
    groq`
    *[
      _type == "series" &&
      slug.current == $series &&
      category->slug.current == $category
    ][0]{
      _id,
      _type,
      title,
      "slug": slug.current,
      year,
      description,
      coverImage,
      category->{_id, title, "slug": slug.current},
      works[]{
        title,
        year,
        medium,
        dimensions,
        photo, 
        shortDescription,
        image{
          ...,
          alt
        },
        description
      }
    }`,
    { category: categorySlug, series: second }
  );

  if (seriesData) {
    pageType = "series";
    data = seriesData;
  } else {
    // Fallback: WORK
    const workData = await sanity.fetch(
      groq`
      *[
        _type == "work" &&
        slug.current == $work &&
        category->slug.current == $category
      ][0]{
        _id,
        _type,
        title,
        "slug": slug.current,
        year,
        medium,
        dimensions,
        availability,
        image{
          ...,
          alt
        },
        description,
        category->{title, "slug": slug.current}
      }`,
      { category: categorySlug, work: second }
    );

    if (workData) {
      pageType = "work";
      data = workData;
    }
  }
}

// 404 hvis ingen data
if (!data || !pageType) {
  Astro.response.status = 404;
}
---

{Astro.response.status === 404 ? (
  <main style="padding:2rem">
    <h1>404</h1>
    <p>Siden finnes ikke.</p>
  </main>
) : (
  <>
    {pageType === "category" && <CategoryTemplate data={data} />}
    {pageType === "series" && <SeriesTemplate data={data} />}
    {pageType === "work" && <WorkTemplate data={data} />}
  </>
)}