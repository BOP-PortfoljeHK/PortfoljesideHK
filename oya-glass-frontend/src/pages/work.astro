---
import groq from "groq";
import { sanity } from "../lib/sanityClient";
import Layout from "../layouts/Layout.astro";
import { urlFor } from "../lib/sanityImage";

type CategoryItem = {
  _id: string;
  title: string;
  slug: string;
  description?: string;
  coverImage?: any;
};

const query = groq`
*[_type == "category" && defined(slug.current)] | order(title asc) {
  _id,
  title,
  "slug": slug.current,
  description,
  coverImage
}
`;

const categories: CategoryItem[] = await sanity.fetch(query);

function getCategoryAlt(category: CategoryItem) {
  return category.title;
}
---

<Layout title="Work">
  <main class="px-4 py-16 md:px-6 lg:px-8">
    <div class="mx-auto w-full max-w-7xl">

      <section class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {categories.map((category: CategoryItem) => (
          <a
            href={`/${category.slug}`}
            class="group relative block min-h-105 overflow-hidden rounded-2xl bg-neutral-200 md:min-h-115 lg:min-h-130"
          >
            {category.coverImage ? (
              <img
                src={urlFor(category.coverImage).width(1400).height(1000).fit("crop").url()}
                alt={getCategoryAlt(category)}
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
              />
            ) : (
              <div class="absolute inset-0 bg-linear-to-br from-neutral-300 to-neutral-400"></div>
            )}

            <div class="absolute inset-0 bg-linear-to-t from-black/75 via-black/30 to-black/5 transition-opacity duration-300 group-hover:opacity-90"></div>

            <div class="absolute inset-x-0 bottom-0 z-10 p-6 md:p-8">
              <h2 class="mb-2 text-3xl font-semibold leading-tight text-white">
                {category.title}
              </h2>

              {category.description && (
                <p class="max-w-xl text-sm leading-6 text-white/90 md:text-base">
                  {category.description}
                </p>
              )}
            </div>
          </a>
        ))}
      </section>
    </div>
  </main>
</Layout>