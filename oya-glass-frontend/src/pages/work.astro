---
import groq from "groq";
import { sanity } from "../lib/sanityClient";
import Layout from "../layouts/Layout.astro";
import { urlFor } from "../lib/sanityImage";

type CategoryItem = {
  _id: string;
  title: string;
  slug: string;
  description?: string;
  coverImage?: any;
};

const query = groq`
*[_type == "category" && defined(slug.current)] | order(title asc) {
  _id,
  title,
  "slug": slug.current,
  description,
  coverImage
}
`;

const categories: CategoryItem[] = await sanity.fetch(query);

function getCategoryAlt(category: CategoryItem) {
  return category.title;
}
---

<Layout title="Work">
  <main class="mx-auto max-w-[1700px] px-6 py-14 md:px-10 md:py-20">
    <section class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-2 md:gap-y-14">
      {categories.map((category: CategoryItem) => (
        <a
          href={`/${category.slug}`}
          class="group block"
        >
          {category.coverImage ? (
            <div class="overflow-hidden rounded-[1.5rem] bg-neutral-200 md:rounded-[1.75rem]">
              <img
                src={urlFor(category.coverImage).width(2000).height(1500).fit("crop").url()}
                alt={getCategoryAlt(category)}
                loading="lazy"
                class="aspect-[4/3] w-full object-cover transition duration-500 group-hover:scale-[1.015]"
              />
            </div>
          ) : (
            <div class="aspect-[4/3] rounded-[1.5rem] bg-neutral-300 md:rounded-[1.75rem]"></div>
          )}

          <div class="mt-3 md:mt-4">
            <h2 class="text-2xl sm:text-3xl md:text-[1.85rem] font-medium leading-tight tracking-tight text-neutral-950">
              {category.title}
            </h2>
          </div>
        </a>
      ))}
    </section>
  </main>
</Layout>