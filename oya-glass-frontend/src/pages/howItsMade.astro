---
import Layout from "../layouts/Layout.astro";
import PortableText from "../components/PortableText.astro";
import groq from "groq";
import { sanity } from "../lib/sanityClient";

const howItsMadeVideo = await sanity.fetch(groq`
  *[_type == "howItsMadeVideo"][0]{
    title,
    description,
    videos[]{
      _key,
      title,
      youtubeUrl,
      description,
      images[]{
        alt,
        title,
        description,
        asset->{
          url
        }
      }
    }
  }
`);

function getYoutubeId(url: string | null | undefined) {
  const regExp =
    /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([^&?/]+)/;
  const match = url?.match(regExp);
  return match ? match[1] : null;
}
---

{/* Denne siden viser "How it's made" på nettsiden, viser beskrivelse av prosessen, ved tekst, bilder og/eller videoer */}

<Layout title={howItsMadeVideo?.title ?? "Video"}>
  <main class="mx-auto max-w-5xl space-y-10 px-4 py-16">
    {howItsMadeVideo?.title && (
      <div class="mb-8">
        <h1 class="text-3xl md:text-4xl font-normal tracking-tight">
          {howItsMadeVideo.title}
        </h1>
      </div>
    )}

    {howItsMadeVideo?.description && (
      <div class="max-w-3xl mb-16">
        <PortableText value={howItsMadeVideo.description} />
      </div>
    )}

    <div class="space-y-24">
      {howItsMadeVideo?.videos?.map((item: any, sectionIndex: number) => {
        const videoId = getYoutubeId(item.youtubeUrl);
        const hasVideo = Boolean(videoId);
        const hasImages = Boolean(item.images?.length);

        return (
          <section class="border-t border-gray-300 pt-12">
            <div class="max-w-3xl space-y-5">
              {item.title && (
                <h2 class="text-2xl md:text-[2rem] leading-tight font-normal">
                  {item.title}
                </h2>
              )}

              {item.description && (
                <div>
                  <PortableText value={item.description} />
                </div>
              )}
            </div>

            {(hasVideo || hasImages) && (
              <div class="mt-10 max-w-4xl space-y-6">
                {hasVideo && (
                  <div class="w-full overflow-hidden rounded-md">
                    <div class="aspect-video w-full">
                      <iframe
                        class="w-full h-full"
                        src={`https://www.youtube.com/embed/${videoId}`}
                        title={item.title || "YouTube-video"}
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                      />
                    </div>
                  </div>
                )}

                {hasImages &&
                  (item.images.length === 1 ? (
                    <div class="max-w-4xl">
                      <button
                        type="button"
                        class="block w-full text-left group"
                        data-lightbox-image
                        data-section={sectionIndex}
                        data-index={0}
                        data-src={item.images[0].asset.url}
                        data-alt={item.images[0].alt || item.title || ""}
                        data-title={item.images[0].title || ""}
                        data-description={item.images[0].description || ""}
                      >
                        <div class="overflow-hidden rounded-md bg-white">
                          <img
                            src={item.images[0].asset.url}
                            alt={item.images[0].alt || item.title || ""}
                            class="w-full max-h-[70vh] object-contain transition duration-200 group-hover:opacity-95"
                          />
                        </div>
                      </button>
                    </div>
                  ) : (
                    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                      {item.images.map((img: any, imageIndex: number) => (
                        <button
                          type="button"
                          class="block w-full text-left group"
                          data-lightbox-image
                          data-section={sectionIndex}
                          data-index={imageIndex}
                          data-src={img.asset.url}
                          data-alt={img.alt || item.title || ""}
                          data-title={img.title || ""}
                          data-description={img.description || ""}
                        >
                          <div class="overflow-hidden rounded-md bg-white">
                            <img
                              src={img.asset.url}
                              alt={img.alt || item.title || ""}
                              class="w-full aspect-4/5 object-cover transition duration-200 group-hover:opacity-95"
                            />
                          </div>
                        </button>
                      ))}
                    </div>
                  ))}
              </div>
            )}
          </section>
        );
      })}
    </div>
  </main>

  <div
    id="lightbox"
    class="fixed inset-0 z-99999 hidden bg-black/90 p-4 md:p-8"
    aria-hidden="true"
  >
    <div class="relative flex h-full w-full flex-col items-center justify-center">
      <button
        id="lightbox-close"
        type="button"
        class="absolute right-2 top-2 md:right-4 md:top-4 text-white text-4xl leading-none"
        aria-label="Close"
      >
        &times;
      </button>

      <button
        id="lightbox-prev"
        type="button"
        class="absolute left-2 md:left-4 px-3 py-2 text-4xl leading-none text-white"
        aria-label="Previous image"
      >
        &#8249;
      </button>

      <img
        id="lightbox-image"
        src=""
        alt=""
        class="max-h-[75vh] max-w-full rounded-lg object-contain"
      />

      <button
        id="lightbox-next"
        type="button"
        class="absolute right-2 md:right-4 px-3 py-2 text-4xl leading-none text-white"
        aria-label="Next image"
      >
        &#8250;
      </button>

      <div class="mt-6 max-w-2xl text-center text-white">
        <p id="lightbox-title" class="text-base font-medium text-white"></p>
        <p id="lightbox-description" class="mt-1 text-sm text-white/70"></p>
        <p id="lightbox-counter" class="mt-2 text-xs text-white/50"></p>
      </div>
    </div>
  </div>

  <script is:inline>
    const lightbox = document.getElementById("lightbox");
    const lightboxImage = document.getElementById("lightbox-image");
    const lightboxTitle = document.getElementById("lightbox-title");
    const lightboxDescription = document.getElementById("lightbox-description");
    const lightboxCounter = document.getElementById("lightbox-counter");
    const closeBtn = document.getElementById("lightbox-close");
    const prevBtn = document.getElementById("lightbox-prev");
    const nextBtn = document.getElementById("lightbox-next");

    const triggers = Array.from(document.querySelectorAll("[data-lightbox-image]"));
    const groupedImages = {};

    triggers.forEach((trigger) => {
      const section = trigger.dataset.section;
      if (!groupedImages[section]) groupedImages[section] = [];

      groupedImages[section].push({
        src: trigger.dataset.src,
        alt: trigger.dataset.alt || "",
        title: trigger.dataset.title || "",
        description: trigger.dataset.description || "",
      });
    });

    let currentSection = null;
    let currentIndex = 0;

    function updateLightbox() {
      if (currentSection === null) return;

      const images = groupedImages[currentSection];
      const current = images[currentIndex];

      lightboxImage.src = current.src;
      lightboxImage.alt = current.alt;
      lightboxTitle.textContent = current.title || "";
      lightboxDescription.textContent = current.description || "";
      lightboxCounter.textContent = `${currentIndex + 1}/${images.length}`;

      const hasMultiple = images.length > 1;
      prevBtn.style.display = hasMultiple ? "block" : "none";
      nextBtn.style.display = hasMultiple ? "block" : "none";
    }

    function openLightbox(section, index) {
      currentSection = section;
      currentIndex = index;
      updateLightbox();
      lightbox.classList.remove("hidden");
      document.body.style.overflow = "hidden";
      lightbox.setAttribute("aria-hidden", "false");
    }

    function closeLightbox() {
      lightbox.classList.add("hidden");
      document.body.style.overflow = "";
      lightbox.setAttribute("aria-hidden", "true");
      lightboxImage.src = "";
      lightboxImage.alt = "";
      lightboxTitle.textContent = "";
      lightboxDescription.textContent = "";
      lightboxCounter.textContent = "";
    }

    function showPrev() {
      if (currentSection === null) return;
      const images = groupedImages[currentSection];
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      updateLightbox();
    }

    function showNext() {
      if (currentSection === null) return;
      const images = groupedImages[currentSection];
      currentIndex = (currentIndex + 1) % images.length;
      updateLightbox();
    }

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        openLightbox(trigger.dataset.section, Number(trigger.dataset.index));
      });
    });

    closeBtn?.addEventListener("click", closeLightbox);
    prevBtn?.addEventListener("click", showPrev);
    nextBtn?.addEventListener("click", showNext);

    lightbox?.addEventListener("click", (event) => {
      if (event.target === lightbox) closeLightbox();
    });

    document.addEventListener("keydown", (event) => {
      if (lightbox.classList.contains("hidden")) return;
      if (event.key === "Escape") closeLightbox();
      if (event.key === "ArrowLeft") showPrev();
      if (event.key === "ArrowRight") showNext();
    });
  </script>
</Layout>