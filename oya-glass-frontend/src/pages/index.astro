---
import Layout from "../layouts/Layout.astro";
import groq from "groq";
import { sanity } from "../lib/sanityClient";
import { urlFor } from "../lib/sanityImage";

const data = await sanity.fetch(groq`
  *[_type == "homePage"][0]{
    heroImage{
      ...,
      alt
    }
  }
`);
---

<Layout>
  <section class="relative h-[70vh] min-h-125 w-full overflow-hidden">
    {data?.heroImage && (
      <img
        src={urlFor(data.heroImage).width(1800).height(1200).fit("crop").url()}
        alt={data.heroImage.alt || "Forsidebilde"}
        class="absolute inset-0 h-full w-full object-cover"
      />
    )}

    <div class="absolute inset-0 bg-black/35"></div>

    <div class="relative z-10 mx-auto flex h-full max-w-7xl items-end px-6 pb-16 md:px-10">
      <div class="max-w-2xl text-white">
        <h1 class="text-4xl font-semibold leading-tight md:text-6xl">
          Hanna K
        </h1>
        <p class="mt-4 text-base leading-7 text-white/90 md:text-lg">
          Dette er en porteføljeside for HK, laget med Astro og Sanity.
        </p>
      </div>
    </div>
  </section>
</Layout>