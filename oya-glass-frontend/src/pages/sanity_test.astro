---
import groq from "groq";
import { sanity } from "../lib/sanityClient";

type Doc = {
  _id: string;
  _type: string;
  title?: string;
  name?: string;
};

const query = groq`*[_type != "sanity.imageAsset" && _type != "sanity.fileAsset"][0..49]{
  _id,
  _type,
  title,
  name
} | order(_type asc)`;

const docs = await sanity.fetch<Doc[]>(query);
---

<html lang="no">
  <head>
    <meta charset="utf-8" />
    <title>Sanity test</title>
  </head>
  <body style="font-family: system-ui; padding: 24px;">
    <h1>Sanity test</h1>
    <p>Fant {docs.length} dokumenter</p>

    {docs.length === 0 ? (
      <p>Ingen dokumenter funnet. Har du publisert noe i Sanity Studio?</p>
    ) : (
      <ul>
        {docs.map((d) => (
          <li>
            <strong>{d._type}</strong> — {d.title ?? d.name ?? "(ingen title/name)"}
          </li>
        ))}
      </ul>
    )}
  </body>
</html>
