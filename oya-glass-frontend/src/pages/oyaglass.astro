---
import Layout from "../layouts/Layout.astro";
import PortableText from "../components/PortableText.astro";
import groq from "groq";
import { sanity } from "../lib/sanityClient";

const oyaglass = await sanity.fetch(groq`
  *[_type == "oyaglass"][0]{
    title,
    logo{
      asset->{
        url
      }
    },
    images[]{
      asset->{
        url
      },
      alt
    },
    bio
  }
`);
---

{/* Infoside om Øya Glass studio */}

{/* Tittel for selve siden og heading med tittel i. Viser også logobilde dersom det er lagt til i Sanity */}
<Layout title={oyaglass?.title}>
  <div class="flex justify-center mt-5">
    {oyaglass?.logo && (
        <img
          src={oyaglass.logo.asset.url}
          alt={`${oyaglass.title} logo`}
          class="w-full max-w-lg md:max-w-2xl lg:max-w-none max-h-200 md:max-h-160 object-contain"
        />
    )}
    </div>

  <section class="mx-auto max-w-7xl px-4 py-28 md:px-10">
    <h1 class="mb-10 text-3xl leading-[1.1] text-center tracking-wide text-neutral-950 sm:text-4xl md:text-5xl">{oyaglass?.title}</h1>
    
    {/* Viser biografi eller beskrivelse av studioet, hentet fra Sanity */}
    <div class="mx-auto max-w-4xl text-center mt-2 mb-16">
      <div class="text-lg leading-relaxed">
        <PortableText value={oyaglass?.bio} />
      </div>
    </div>

    {/* Viser bilder, dersom det er lagt til i Sanity */}
    {oyaglass?.images?.length > 0 && (
      <div class="columns-1 sm:columns-1 md:columns-2 gap-3">
        {oyaglass.images.map((image: any) => (
          <img
            src={image?.asset?.url}
            alt={image?.alt || oyaglass?.title || "Øya glass studio"}
            class="mb-4 w-full break-inside-avoid object-cover rounded"
          />
        ))}
      </div>
    )}
  </section>
</Layout>