---
import "../styles/global.css";
import Header from "../components/Header.astro";

const { title = "Øya glass studio" } = Astro.props;
---

<!doctype html>
<html lang="no">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
	</head>

	<body class="min-h-screen">
		<Header />
		<main>
			<slot />
		</main>
	</body>
</html>

