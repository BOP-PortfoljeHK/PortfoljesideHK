---
import Layout from "../layouts/Layout.astro";
import { urlFor } from "../lib/sanityImage";

const { data } = Astro.props;

const galleryItems =
  data?.works?.map((work: any) => ({
    image: work.image,
    workTitle: work.title,
    year: work.year,
    medium: work.medium,
    dimensions: work.dimensions,
    alt:
      typeof work?.image?.alt === "string" && work.image.alt.trim().length > 0
        ? work.image.alt
        : work.title,
  })) ?? [];

function normalizeMarks(children: any[] = []) {
  return children.map((child: any) => {
    const text = child.text ?? "";

    if (child.marks?.includes("strong")) {
      return { type: "strong", text };
    }

    if (child.marks?.includes("em")) {
      return { type: "em", text };
    }

    return { type: "text", text };
  });
}

const descriptionBlocks =
  data?.description
    ?.filter((block: any) => block._type === "block")
    .map((block: any) => ({
      style: block.style ?? "normal",
      children: normalizeMarks(block.children ?? []),
    })) ?? [];
---

<Layout title={data.title}>
  <main class="mx-auto max-w-7xl px-6 py-12 md:px-10">
    <section class="mb-14">
      <p class="mb-3 text-sm uppercase tracking-[0.2em] text-neutral-500">
        Series
      </p>

      <h1 class="mb-6 text-4xl font-semibold tracking-tight md:text-5xl">
        {data.title}
      </h1>

      {descriptionBlocks.length > 0 && (
        <div class="max-w-3xl space-y-5">
          {descriptionBlocks.map((block: any) =>
            block.style === "h2" ? (
              <h2 class="text-2xl font-semibold text-neutral-900">
                {block.children.map((child: any) =>
                  child.type === "strong" ? (
                    <strong class="font-semibold text-neutral-900">{child.text}</strong>
                  ) : child.type === "em" ? (
                    <em class="italic">{child.text}</em>
                  ) : (
                    child.text
                  )
                )}
              </h2>
            ) : block.style === "h3" ? (
              <h3 class="text-xl font-semibold text-neutral-900">
                {block.children.map((child: any) =>
                  child.type === "strong" ? (
                    <strong class="font-semibold text-neutral-900">{child.text}</strong>
                  ) : child.type === "em" ? (
                    <em class="italic">{child.text}</em>
                  ) : (
                    child.text
                  )
                )}
              </h3>
            ) : block.style === "blockquote" ? (
              <blockquote class="border-l-4 border-neutral-300 pl-4 italic text-neutral-600">
                {block.children.map((child: any) =>
                  child.type === "strong" ? (
                    <strong class="font-semibold text-neutral-900">{child.text}</strong>
                  ) : child.type === "em" ? (
                    <em class="italic">{child.text}</em>
                  ) : (
                    child.text
                  )
                )}
              </blockquote>
            ) : (
              <p class="text-base leading-8 text-neutral-700">
                {block.children.map((child: any) =>
                  child.type === "strong" ? (
                    <strong class="font-semibold text-neutral-900">{child.text}</strong>
                  ) : child.type === "em" ? (
                    <em class="italic">{child.text}</em>
                  ) : (
                    child.text
                  )
                )}
              </p>
            )
          )}
        </div>
      )}
    </section>

    {galleryItems.length > 0 && (
      <section class="grid gap-12 lg:grid-cols-2">
        {galleryItems.map((item: any, index: number) => {
          if (!item.image) return null;

          const previewUrl = urlFor(item.image).width(1800).fit("max").url();
          const zoomUrl = urlFor(item.image).width(2600).fit("max").url();
          const meta = [item.year, item.medium, item.dimensions]
            .filter(Boolean)
            .join(" · ");

          return (
            <figure class="group">
              <button
                type="button"
                class="block w-full overflow-hidden rounded-2xl"
                data-lightbox-index={index}
                data-lightbox-image={zoomUrl}
                data-lightbox-alt={item.alt}
                data-lightbox-title={item.workTitle}
                data-lightbox-meta={meta}
                aria-label={`Åpne større bilde av ${item.workTitle}`}
              >
                <img
                  src={previewUrl}
                  alt={item.alt}
                  loading="lazy"
                  class="w-full rounded-2xl object-cover shadow-sm transition duration-300 group-hover:scale-[1.01]"
                />
              </button>

              <figcaption class="mt-4 text-sm text-neutral-700">
                <p class="text-lg font-medium text-neutral-900">{item.workTitle}</p>
                {meta && <p class="mt-1 text-neutral-500">{meta}</p>}
              </figcaption>
            </figure>
          );
        })}
      </section>
    )}
  </main>

  <div
    id="lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 p-4"
    aria-hidden="true"
  >
    <button
      id="lightbox-close"
      type="button"
      class="absolute right-6 top-4 rounded-full bg-white/10 px-4 py-2 text-sm text-white backdrop-blur transition hover:bg-white/20"
      aria-label="Lukk bildevisning"
    >
      Lukk
    </button>

    <button
      id="lightbox-prev"
      type="button"
      class="absolute left-6 top-1/2 -translate-y-1/2 rounded-full bg-white/10 px-4 py-3 text-2xl text-white backdrop-blur transition hover:bg-white/20"
      aria-label="Forrige bilde"
    >
      ←
    </button>

    <button
      id="lightbox-next"
      type="button"
      class="absolute right-4 top-1/2 -translate-y-1/2 rounded-full bg-white/10 px-4 py-3 text-2xl text-white backdrop-blur transition hover:bg-white/20"
      aria-label="Neste bilde"
    >
      →
    </button>

    <div class="flex max-h-[90vh] max-w-[90vw] flex-col items-center">
      <img
        id="lightbox-image"
        src=""
        alt=""
        class="max-h-[80vh] max-w-[90vw] object-contain"
      />

      <p
        id="lightbox-caption"
        class="mt-4 text-center text-base font-medium text-white"
      ></p>

      <p
        id="lightbox-meta"
        class="mt-1 text-center text-sm text-white/80"
      ></p>

      <p
        id="lightbox-counter"
        class="mt-2 text-center text-xs tracking-wide text-white/60"
      ></p>
    </div>
  </div>

  <script>
    const lightbox = document.getElementById("lightbox");
    const lightboxImage = document.getElementById("lightbox-image");
    const lightboxCaption = document.getElementById("lightbox-caption");
    const lightboxMeta = document.getElementById("lightbox-meta");
    const lightboxCounter = document.getElementById("lightbox-counter");
    const closeButton = document.getElementById("lightbox-close");
    const prevButton = document.getElementById("lightbox-prev");
    const nextButton = document.getElementById("lightbox-next");
    const triggers = Array.from(document.querySelectorAll("[data-lightbox-image]"));

    let currentIndex = 0;

    function showImage({ index }: { index: any; }): void {
      const trigger = triggers[index];
      if (!trigger || !lightbox || !lightboxImage || !lightboxCaption || !lightboxMeta) return;

      const src = trigger.getAttribute("data-lightbox-image");
      const alt = trigger.getAttribute("data-lightbox-alt") || "";
      const title = trigger.getAttribute("data-lightbox-title") || "";
      const meta = trigger.getAttribute("data-lightbox-meta") || "";

      if (!src) return;

      currentIndex = index;
      lightboxImage.setAttribute("src", src);
      lightboxImage.setAttribute("alt", alt);
      lightboxCaption.textContent = title;
      lightboxMeta.textContent = meta;

      if (lightboxCounter) {
        lightboxCounter.textContent = `${index + 1} / ${triggers.length}`;
      }

      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      lightbox.setAttribute("aria-hidden", "false");
    }

    function showNext() {
      if (triggers.length === 0) return;
      const nextIndex = (currentIndex + 1) % triggers.length;
      showImage({ index: nextIndex });
    }

    function showPrev() {
      if (triggers.length === 0) return;
      const prevIndex = (currentIndex - 1 + triggers.length) % triggers.length;
      showImage({ index: prevIndex });
    }

    function closeLightbox() {
      if (!lightbox || !lightboxImage || !lightboxCaption || !lightboxMeta) return;

      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      lightbox.setAttribute("aria-hidden", "true");
      lightboxImage.setAttribute("src", "");
      lightboxImage.setAttribute("alt", "");
      lightboxCaption.textContent = "";
      lightboxMeta.textContent = "";

      if (lightboxCounter) {
        lightboxCounter.textContent = "";
      }
    }

    triggers.forEach((trigger, index) => {
      trigger.addEventListener("click", () => {
        showImage({ index });
      });
    });

    closeButton?.addEventListener("click", closeLightbox);
    nextButton?.addEventListener("click", showNext);
    prevButton?.addEventListener("click", showPrev);

    lightbox?.addEventListener("click", (event) => {
      if (event.target === lightbox) closeLightbox();
    });

    document.addEventListener("keydown", (event) => {
      const isOpen = lightbox?.getAttribute("aria-hidden") === "false";

      if (!isOpen) return;

      if (event.key === "Escape") closeLightbox();
      if (event.key === "ArrowRight") showNext();
      if (event.key === "ArrowLeft") showPrev();
    });
  </script>
</Layout>