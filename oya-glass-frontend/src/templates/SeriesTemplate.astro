---
import Layout from "../layouts/Layout.astro";
import { urlFor } from "../lib/sanityImage";

const { data } = Astro.props;

const galleryItems =
  data?.works?.map((work: any) => ({
    image: work.image,
    workTitle: work.title,
    year: work.year,
    medium: work.medium,
    dimensions: work.dimensions,
    alt:
      typeof work?.image?.alt === "string" && work.image.alt.trim().length > 0
        ? work.image.alt
        : work.title,
  })) ?? [];

function normalizeMarks(children: any[] = []) {
  return children.map((child: any) => {
    const text = child.text ?? "";

    if (child.marks?.includes("strong")) {
      return { type: "strong", text };
    }

    if (child.marks?.includes("em")) {
      return { type: "em", text };
    }

    return { type: "text", text };
  });
}

const descriptionBlocks =
  data?.description
    ?.filter((block: any) => block._type === "block")
    .map((block: any) => ({
      style: block.style ?? "normal",
      children: normalizeMarks(block.children ?? []),
    })) ?? [];
---

<Layout title={data.title}>
  <main class="mx-auto max-w-[1700px] px-6 py-14 md:px-10 md:py-20">
    <section class="mx-auto mb-14 max-w-[860px] md:mb-18">
      <p class="mb-3 text-xs font-medium uppercase tracking-[0.22em] text-neutral-500">
        Series
      </p>

      <h1 class="mb-5 text-3xl font-medium leading-tight tracking-tight text-neutral-950 sm:text-4xl md:text-5xl">
        {data.title}
      </h1>

      {descriptionBlocks.length > 0 && (
        <div class="space-y-4">
          {descriptionBlocks.map((block: any) =>
            block.style === "h2" ? (
              <h2 class="text-xl font-medium leading-tight text-neutral-900 sm:text-2xl">
                {block.children.map((child: any) =>
                  child.type === "strong" ? (
                    <strong class="font-semibold text-neutral-900">{child.text}</strong>
                  ) : child.type === "em" ? (
                    <em class="italic">{child.text}</em>
                  ) : (
                    child.text
                  )
                )}
              </h2>
            ) : block.style === "h3" ? (
              <h3 class="text-lg font-medium leading-tight text-neutral-900 sm:text-xl">
                {block.children.map((child: any) =>
                  child.type === "strong" ? (
                    <strong class="font-semibold text-neutral-900">{child.text}</strong>
                  ) : child.type === "em" ? (
                    <em class="italic">{child.text}</em>
                  ) : (
                    child.text
                  )
                )}
              </h3>
            ) : block.style === "blockquote" ? (
              <blockquote class="border-l-2 border-neutral-300 pl-4 italic text-neutral-600">
                {block.children.map((child: any) =>
                  child.type === "strong" ? (
                    <strong class="font-semibold text-neutral-900">{child.text}</strong>
                  ) : child.type === "em" ? (
                    <em class="italic">{child.text}</em>
                  ) : (
                    child.text
                  )
                )}
              </blockquote>
            ) : (
              <p class="text-base leading-7 text-neutral-700">
                {block.children.map((child: any) =>
                  child.type === "strong" ? (
                    <strong class="font-semibold text-neutral-900">{child.text}</strong>
                  ) : child.type === "em" ? (
                    <em class="italic">{child.text}</em>
                  ) : (
                    child.text
                  )
                )}
              </p>
            )
          )}
        </div>
      )}
    </section>

    {galleryItems.length > 0 && (
      <section class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-2 md:gap-y-14">
        {galleryItems.map((item: any, index: number) => {
          if (!item.image) return null;

          const previewUrl = urlFor(item.image).width(2200).height(1650).fit("crop").url();
          const zoomUrl = urlFor(item.image).width(2600).fit("max").url();
          const meta = [item.year, item.medium, item.dimensions]
            .filter(Boolean)
            .join(" · ");

          return (
            <figure class="group">
              <button
                type="button"
                class="block w-full overflow-hidden bg-neutral-200"
                data-lightbox-index={index}
                data-lightbox-image={zoomUrl}
                data-lightbox-alt={item.alt}
                data-lightbox-title={item.workTitle}
                data-lightbox-meta={meta}
                aria-label={`Open for a larger view of ${item.workTitle}`}
              >
                <img
                  src={previewUrl}
                  alt={item.alt}
                  loading="lazy"
                  class="aspect-[4/3] w-full object-cover transition duration-500 group-hover:scale-[1.015]"
                />
              </button>

              <figcaption class="mt-3 md:mt-4">
                <p class="text-xl font-medium leading-tight tracking-tight text-neutral-950 sm:text-2xl md:text-[1.85rem]">
                  {item.workTitle}
                </p>
                {meta && (
                  <p class="mt-1 text-sm text-neutral-500">{meta}</p>
                )}
              </figcaption>
            </figure>
          );
        })}
      </section>
    )}
  </main>

  <div
    id="lightbox"
    class="fixed inset-0 z-[10000] hidden items-center justify-center bg-black/95 px-4 py-6"
    aria-hidden="true"
  >
    <button
      id="lightbox-close"
      type="button"
      class="absolute right-4 top-4 z-20 rounded-full bg-white/10 px-4 py-2 text-sm text-white backdrop-blur transition hover:bg-white/20"
    >
      Close
    </button>

    <div class="flex w-full max-w-[1400px] flex-col items-center">
      <img
        id="lightbox-image"
        src=""
        alt=""
        class="max-h-[70vh] w-auto max-w-full object-contain md:max-h-[80vh]"
      />

      <div class="mt-4 text-center">
        <p id="lightbox-caption" class="text-base font-medium text-white"></p>
        <p id="lightbox-meta" class="mt-1 text-sm text-white/70"></p>
        <p id="lightbox-counter" class="mt-2 text-xs text-white/50"></p>
      </div>

      <div class="mt-6 flex w-full items-center justify-between md:hidden">
        <button
          id="lightbox-prev-mobile"
          class="rounded-full bg-white/10 px-5 py-3 text-xl text-white backdrop-blur transition hover:bg-white/20"
        >
          ←
        </button>

        <button
          id="lightbox-next-mobile"
          class="rounded-full bg-white/10 px-5 py-3 text-xl text-white backdrop-blur transition hover:bg-white/20"
        >
          →
        </button>
      </div>
    </div>

    <button
      id="lightbox-prev"
      class="absolute left-6 top-1/2 hidden -translate-y-1/2 rounded-full bg-white/10 px-4 py-3 text-2xl text-white backdrop-blur transition hover:bg-white/20 md:block"
    >
      ←
    </button>

    <button
      id="lightbox-next"
      class="absolute right-6 top-1/2 hidden -translate-y-1/2 rounded-full bg-white/10 px-4 py-3 text-2xl text-white backdrop-blur transition hover:bg-white/20 md:block"
    >
      →
    </button>
  </div>

  <script>
    const lightbox = document.getElementById("lightbox");
    const lightboxImage = document.getElementById("lightbox-image") as HTMLImageElement | null;
    const lightboxCaption = document.getElementById("lightbox-caption");
    const lightboxMeta = document.getElementById("lightbox-meta");
    const lightboxCounter = document.getElementById("lightbox-counter");

    const closeButton = document.getElementById("lightbox-close");
    const prevButton = document.getElementById("lightbox-prev");
    const nextButton = document.getElementById("lightbox-next");
    const prevMobile = document.getElementById("lightbox-prev-mobile");
    const nextMobile = document.getElementById("lightbox-next-mobile");

    const triggers = Array.from(document.querySelectorAll("[data-lightbox-image]"));
    let currentIndex = 0;

    function showImage({ index }: { index: number }) {
      const trigger = triggers[index];
      if (!trigger) return;

      const src = trigger.getAttribute("data-lightbox-image") || "";
      const alt = trigger.getAttribute("data-lightbox-alt") || "";
      const title = trigger.getAttribute("data-lightbox-title") || "";
      const meta = trigger.getAttribute("data-lightbox-meta") || "";

      currentIndex = index;

      if (!lightboxImage || !lightboxCaption || !lightboxMeta || !lightboxCounter || !lightbox) return;

      lightboxImage.src = src;
      lightboxImage.alt = alt;
      lightboxCaption.textContent = title;
      lightboxMeta.textContent = meta;
      lightboxCounter.textContent = `${index + 1} / ${triggers.length}`;

      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      lightbox.setAttribute("aria-hidden", "false");

      document.body.classList.add("overflow-hidden");
    }

    function showNext() {
      const nextIndex = (currentIndex + 1) % triggers.length;
      showImage({ index: nextIndex });
    }

    function showPrev() {
      const prevIndex = (currentIndex - 1 + triggers.length) % triggers.length;
      showImage({ index: prevIndex });
    }

    function closeLightbox() {
      if (!lightbox) return;

      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      lightbox.setAttribute("aria-hidden", "true");

      if (lightboxImage) lightboxImage.src = "";
      if (lightboxCaption) lightboxCaption.textContent = "";
      if (lightboxMeta) lightboxMeta.textContent = "";
      if (lightboxCounter) lightboxCounter.textContent = "";

      document.body.classList.remove("overflow-hidden");
    }

    triggers.forEach((trigger, index) => {
      trigger.addEventListener("click", () => showImage({ index }));
    });

    closeButton?.addEventListener("click", closeLightbox);
    prevButton?.addEventListener("click", showPrev);
    nextButton?.addEventListener("click", showNext);
    prevMobile?.addEventListener("click", showPrev);
    nextMobile?.addEventListener("click", showNext);

    lightbox?.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener("keydown", (e) => {
      if (!lightbox || lightbox.getAttribute("aria-hidden") === "true") return;

      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowRight") showNext();
      if (e.key === "ArrowLeft") showPrev();
    });
  </script>
</Layout>