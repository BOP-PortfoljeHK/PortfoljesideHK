---
// Midlertidig template for serie-sider.
import { urlFor } from "../lib/sanityImage";
const { data } = Astro.props;
---

<main>
  <h1>{data.title}</h1>

  {data.coverImage && (
    <img
      src={urlFor(data.coverImage).width(1400).quality(80).url()}
      alt={data.title}
      style="max-width:600px; height:auto; display:block; margin:1rem 0;"
      loading="lazy"
    />
  )}

  {data.description && (
    <div>
      {data.description.map((block: any) =>
        block.children?.map((child: any) => <p>{child.text}</p>)
      )}
    </div>
  )}

  <h2>Verk i serien</h2>

  <ul>
    {data.works?.map((work: any) => (
      <li>
        <a href={`/${data.category.slug}/${data.slug}/${work.slug}`}>
          {work.title} {work.year && `(${work.year})`}
        </a>
      </li>
    ))}
  </ul>
</main>