---
import Layout from "../layouts/Layout.astro";
import { urlFor } from "../lib/sanityImage";
import PortableText from "../components/PortableText.astro";

const { data } = Astro.props;

const images =
  Array.isArray(data?.images) && data.images.length > 0
    ? data.images
    : data?.image
      ? [data.image]
      : [];

const galleryImages = images
  .filter((image: any) => image)
  .map((image: any) => {
    const alt =
      typeof image?.alt === "string" && image.alt.trim().length > 0
        ? image.alt
        : data?.title ?? "Work";

    return {
      image,
      alt,
      previewUrl: urlFor(image).width(1800).fit("max").url(),
      zoomUrl: urlFor(image).width(2600).fit("max").url(),
    };
  });
---

{/* "Mal-side" for å vise enkeltverk basert på slug fra Sanity */}

{/* Tittel til siden og beskrivelse */}
<Layout title={data.title}>
  <main class="mx-auto max-w-500 px-6 py-14 md:px-10 md:py-20">
    <section class="mx-auto mb-10 max-w-215 md:mb-18">
  
        <p class="mb-3 text-sm font-medium uppercase tracking-[0.3em] text-neutral-600">
          Work
        </p>

        {/* Tittel på verket */}
      <h1 class="mb-4 text-3xl leading-[1.1] tracking-wide text-neutral-950 sm:text-4xl md:text-5xl">
          {data.title}
      </h1>

      {/* Viser årstallet for verket */}
       <h2 class="mb-20 mt-2 text-xl font-medium tracking-wide text-neutral-600">
        {data.year}
      </h2>

      {/* Beskrivelse av verket */}
        {data.description && (
          <div class="max-w-4xl">
            <PortableText value={data.description} />
          </div>
        )}

    </section>

    {/* Bildevisning */}
<div class="mt-14 md:mt-20">
  {galleryImages.length > 0 && (
    <section
      class={`grid gap-x-8 gap-y-12 md:gap-y-14 mx-auto ${
        galleryImages.length === 1
          ? "grid-cols-1 max-w-6xl"
          : galleryImages.length === 2
            ? "grid-cols-1 md:grid-cols-2 max-w-6xl"
            : "grid-cols-1 md:grid-cols-3 max-w-7xl"
      }`}
    >
      {galleryImages.map((item: any) => (
        <figure class="group">
          <button
            type="button"
            class="block w-full overflow-hidden focus:outline-none"
            data-lightbox-image={item.zoomUrl}
            data-lightbox-alt={item.alt}
            data-lightbox-title={data.title}
            data-lightbox-meta={data.year ?? ""}
            aria-label={`Open for a larger view of ${data.title}`}
          >
            <img
              src={item.previewUrl}
              alt={item.alt}
              loading="lazy"
              class="w-full object-cover shadow-sm transition duration-500 group-hover:scale-[1.05]"
            />
          </button>
        </figure>
      ))}
    </section>
  )}
</div>

        {/* Lightbox for å vise bilder i et stort vindu */}
  <div
    id="lightbox"
    class="fixed inset-0 z-10000 hidden items-center justify-center bg-black/95 px-4 py-6"
    aria-hidden="true"
  >
    <button
      id="lightbox-close"
      type="button"
      class="absolute right-4 top-4 rounded-full bg-white/10 px-4 py-2 text-sm text-white backdrop-blur transition hover:bg-white/20"
      aria-label="Close"
    >
      Close
    </button>

    <div class="flex max-h-[90vh] max-w-[90vw] flex-col items-center">
      <img
        id="lightbox-image"
        src=""
        alt=""
        class="max-h-[70vh] w-auto max-w-full object-contain md:max-h-[80vh]"
      />

      <p
        id="lightbox-caption"
        class="mt-4 text-center text-base font-medium text-white"
      ></p>

      <p
        id="lightbox-meta"
        class="mt-1 text-center text-sm text-white/80"
      ></p>
    </div>
  </div>
    
  </main>

  {/* Lightbox-script for å kunne kjøre lightbox-funksjonaliteten */}
  <script>
    const lightbox = document.getElementById("lightbox");
    const lightboxImage = document.getElementById("lightbox-image");
    const lightboxCaption = document.getElementById("lightbox-caption");
    const lightboxMeta = document.getElementById("lightbox-meta");
    const closeButton = document.getElementById("lightbox-close");
    const triggers = document.querySelectorAll("[data-lightbox-image]");

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const src = trigger.getAttribute("data-lightbox-image");
        const alt = trigger.getAttribute("data-lightbox-alt") || "";
        const title = trigger.getAttribute("data-lightbox-title") || "";
        const meta = trigger.getAttribute("data-lightbox-meta") || "";

        if (!lightbox || !lightboxImage || !lightboxCaption || !lightboxMeta || !src) return;

        lightboxImage.setAttribute("src", src);
        lightboxImage.setAttribute("alt", alt);
        lightboxCaption.textContent = title;
        lightboxMeta.textContent = meta;

        document.body.classList.add("overflow-hidden");

        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        lightbox.setAttribute("aria-hidden", "false");
      });
    });

    function closeLightbox() {
      if (!lightbox || !lightboxImage || !lightboxCaption || !lightboxMeta) return;

      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      lightbox.setAttribute("aria-hidden", "true");

      document.body.classList.remove("overflow-hidden");

      lightboxImage.setAttribute("src", "");
      lightboxImage.setAttribute("alt", "");
      lightboxCaption.textContent = "";
      lightboxMeta.textContent = "";
    }

    closeButton?.addEventListener("click", closeLightbox);

    lightbox?.addEventListener("click", (event) => {
      if (event.target === lightbox) closeLightbox();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeLightbox();
    });
  </script>
</Layout>