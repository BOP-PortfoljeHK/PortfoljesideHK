---
import Layout from "../layouts/Layout.astro";
import { urlFor } from "../lib/sanityImage";
import PortableText from "../components/PortableText.astro";

const { data } = Astro.props;

const imageAlt =
  typeof data?.image?.alt === "string" && data.image.alt.trim().length > 0
    ? data.image.alt
    : data?.title ?? "Verk";

const previewUrl = data?.image
  ? urlFor(data.image).width(1800).fit("max").url()
  : null;

const zoomUrl = data?.image
  ? urlFor(data.image).width(2600).fit("max").url()
  : null;

const meta = [data?.year, data?.medium, data?.dimensions]
  .filter(Boolean)
  .join(" · ");
---

{/* "Mal-side" for å vise enkeltverk basert på slug fra Sanity */}


<Layout title={data.title}>
  <main class="mx-auto max-w-7xl px-6 py-12 md:px-10">
    <section class="grid gap-12 lg:grid-cols-[minmax(0,1.2fr)_minmax(320px,0.8fr)] lg:items-start">
      <div>
        {previewUrl && zoomUrl && (
          <figure class="group">
            <button
              type="button"
              class="block w-full overflow-hidden"
              data-lightbox-image={zoomUrl}
              data-lightbox-alt={imageAlt}
              data-lightbox-title={data.title}
              data-lightbox-meta={meta}
              aria-label={`Åpne større bilde av ${data.title}`}
            >
              <img
                src={previewUrl}
                alt={imageAlt}
                loading="eager"
                class="w-full object-cover shadow-sm transition duration-300 group-hover:scale-[1.01]"
              />
            </button>
          </figure>
        )}
      </div>

      <div class="lg:sticky lg:top-10">
        <p class="mb-3 text-sm uppercase tracking-[0.2em] text-neutral-500">
          Work
        </p>

        <h1 class="mb-4 text-4xl tracking-tight md:text-5xl">
          {data.title}
        </h1>

        {meta && (
          <p class="mb-8 text-base leading-7 text-neutral-500">
            {meta}
          </p>
        )}

        {data.description && (
          <div class="max-w-3xl">
            <PortableText value={data.description} />
          </div>
        )}
      </div>
    </section>
  </main>

  {/* Lightbox for å vise bilder i et stort vindu */}
  <div
    id="lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 p-4"
    aria-hidden="true"
  >
    <button
      id="lightbox-close"
      type="button"
      class="absolute right-4 top-4 rounded-full bg-white/10 px-4 py-2 text-sm text-white backdrop-blur"
      aria-label="Close"
    >
      Close
    </button>

    <div class="flex max-h-[90vh] max-w-[90vw] flex-col items-center">
      <img
        id="lightbox-image"
        src=""
        alt=""
        class="max-h-[80vh] max-w-[90vw] object-contain"
      />

      <p
        id="lightbox-caption"
        class="mt-4 text-center text-base font-medium text-white"
      ></p>

      <p
        id="lightbox-meta"
        class="mt-1 text-center text-sm text-white/80"
      ></p>
    </div>
  </div>

  {/* Lightbox-script for å kunne kjøre lightbox-funksjonaliteten */}
  <script>
    const lightbox = document.getElementById("lightbox");
    const lightboxImage = document.getElementById("lightbox-image");
    const lightboxCaption = document.getElementById("lightbox-caption");
    const lightboxMeta = document.getElementById("lightbox-meta");
    const closeButton = document.getElementById("lightbox-close");
    const triggers = document.querySelectorAll("[data-lightbox-image]");

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const src = trigger.getAttribute("data-lightbox-image");
        const alt = trigger.getAttribute("data-lightbox-alt") || "";
        const title = trigger.getAttribute("data-lightbox-title") || "";
        const meta = trigger.getAttribute("data-lightbox-meta") || "";

        if (!lightbox || !lightboxImage || !lightboxCaption || !lightboxMeta || !src) return;

        lightboxImage.setAttribute("src", src);
        lightboxImage.setAttribute("alt", alt);
        lightboxCaption.textContent = title;
        lightboxMeta.textContent = meta;

        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        lightbox.setAttribute("aria-hidden", "false");
      });
    });

    function closeLightbox() {
      if (!lightbox || !lightboxImage || !lightboxCaption || !lightboxMeta) return;

      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      lightbox.setAttribute("aria-hidden", "true");
      lightboxImage.setAttribute("src", "");
      lightboxImage.setAttribute("alt", "");
      lightboxCaption.textContent = "";
      lightboxMeta.textContent = "";
    }

    closeButton?.addEventListener("click", closeLightbox);

    lightbox?.addEventListener("click", (event) => {
      if (event.target === lightbox) closeLightbox();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeLightbox();
    });
  </script>
</Layout>