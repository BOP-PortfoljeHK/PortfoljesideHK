---
import Layout from "../layouts/Layout.astro";
import { urlFor } from "../lib/sanityImage";

const { data } = Astro.props;
---

<Layout title={data.title}>
  <main class="mx-auto max-w-7xl px-6 py-12 md:px-10">
    <section class="mb-12">
     
      <h1 class="mb-6 text-4xl font-semibold tracking-tight md:text-5xl">
        {data.title}
      </h1>

      {data.coverImage && (
        <img
          src={urlFor(data.coverImage).width(1600).height(900).fit("crop").url()}
          alt={data.title}
          class="mb-6 h-auto w-full rounded-2xl object-cover"
        />
      )}

      {data.description && (
        <p class="max-w-3xl text-base leading-7 text-neutral-700">
          {data.description}
        </p>
      )}
    </section>

    {data.series?.length > 0 && (
      <section class="mb-12">
        <h2 class="mb-4 text-2xl font-semibold">Series</h2>
        <div class="grid gap-4 md:grid-cols-2">
          {data.series.map((series: any) => (
            <a
              href={`/${data.slug}/${series.slug}`}
              class="rounded-2xl border border-neutral-200 p-5 transition hover:-translate-y-0.5 hover:shadow-sm"
            >
              <h3 class="text-lg font-medium">{series.title}</h3>
            </a>
          ))}
        </div>
      </section>
    )}

    {data.works?.length > 0 && (
      <section>
        <h2 class="mb-4 text-2xl font-semibold">Works</h2>
        <div class="grid gap-4 md:grid-cols-2">
          {data.works.map((work: any) => (
            <a
              href={`/${data.slug}/${work.slug}`}
              class="rounded-2xl border border-neutral-200 p-5 transition hover:-translate-y-0.5 hover:shadow-sm"
            >
              <h3 class="text-lg font-medium">{work.title}</h3>
              {work.year && (
                <p class="mt-1 text-sm text-neutral-600">{work.year}</p>
              )}
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>