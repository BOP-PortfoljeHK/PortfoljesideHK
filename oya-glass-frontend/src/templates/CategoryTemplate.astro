---
import Layout from "../layouts/Layout.astro";
import { urlFor } from "../lib/sanityImage";

const { data } = Astro.props;
---

<Layout title={data.title}>
  <main class="mx-auto max-w-[1700px] px-6 py-14 md:px-10 md:py-20">
    <section class="mb-14 md:mb-18">
      <h1 class="text-3xl sm:text-4xl md:text-4xl font-medium leading-tight tracking-tight text-neutral-950">
        {data.title}
      </h1>

      {data.description && (
        <p class="mt-4 max-w-2xl text-base leading-7 text-neutral-600">
          {data.description}
        </p>
      )}
    </section>

    {data.series?.length > 0 && (
      <section class="mb-16 md:mb-20">
        <h2 class="mb-6 text-xs font-medium uppercase tracking-[0.22em] text-neutral-500 md:mb-8">
          Series
        </h2>

        <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-2 md:gap-y-14">
          {data.series.map((series: any) => (
            <a
              href={`/${data.slug}/${series.slug}`}
              class="group block"
            >
              {series.image && (
                <div class="overflow-hidden rounded-[1.5rem] bg-neutral-200 md:rounded-[1.75rem]">
                  <img
                    src={urlFor(series.image).width(2200).height(1650).fit("crop").url()}
                    alt={series.title}
                    class="aspect-[4/3] w-full object-cover transition duration-500 group-hover:scale-[1.015]"
                  />
                </div>
              )}

              <div class="mt-3 md:mt-4">
                <h3 class="text-2xl sm:text-3xl md:text-[1.85rem] font-medium leading-tight tracking-tight text-neutral-950">
                  {series.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {data.works?.length > 0 && (
      <section>
        <h2 class="mb-6 text-xs font-medium uppercase tracking-[0.22em] text-neutral-500 md:mb-8">
          Works
        </h2>

        <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-2 md:gap-y-14">
          {data.works.map((work: any) => (
            <a
              href={`/${data.slug}/${work.slug}`}
              class="group block"
            >
              {work.image && (
                <div class="overflow-hidden rounded-[1.5rem] bg-neutral-200 md:rounded-[1.75rem]">
                  <img
                    src={urlFor(work.image).width(2200).height(1650).fit("crop").url()}
                    alt={work.image?.alt || work.title}
                    class="aspect-[4/3] w-full object-cover transition duration-500 group-hover:scale-[1.015]"
                  />
                </div>
              )}

              <div class="mt-3 md:mt-4">
                <h3 class="text-2xl sm:text-3xl md:text-[1.85rem] font-medium leading-tight tracking-tight text-neutral-950">
                  {work.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>