---
import Layout from "../layouts/Layout.astro";
import { urlFor } from "../lib/sanityImage";

const { data } = Astro.props;

const seriesGridClass =
  data.series?.length > 1
    ? "grid grid-cols-1 gap-y-12 md:grid-cols-2 md:gap-x-8 md:gap-y-14"
    : "grid grid-cols-1 max-w-3xl";

const worksGridClass =
  data.works?.length > 1
    ? "grid grid-cols-1 gap-y-12 md:grid-cols-2 md:gap-x-8 md:gap-y-14"
    : "grid grid-cols-1 max-w-3xl";
---

{/* Denne siden viser innholdet for en spesifikk kategori, via slug fra Sanity */}

<Layout title={data.title}>
  <main class="mx-auto w-full max-w-350 px-4 py-16 md:px-10 md:py-24 lg:px-14">
    <section class="mb-16 md:mb-20">
      <h1 class="text-4xl leading-none tracking-tight text-neutral-950 sm:text-5xl md:text-6xl">
        {data.title}
      </h1>

      {data.description && (
        <p class="mt-6 max-w-3xl text-base leading-8 text-neutral-600 md:text-lg">
          {data.description}
        </p>
      )}
    </section>

    {data.series?.length > 0 && (
      <section class="mb-20 md:mb-28">
        <h2 class="mb-8 text-[0.75rem] font-medium uppercase tracking-[0.28em] text-neutral-500 md:mb-10">
          Series
        </h2>

        <div class={seriesGridClass}>
          {data.series.map((series: any) => (
            <a
              href={`/${data.slug}/${series.slug}`}
              class="group block"
            >
              <div class="mb-4 md:mb-5">
                <h3 class="text-2xl leading-tight tracking-tight text-neutral-950 sm:text-3xl md:text-[2rem]">
                  {series.title}
                </h3>
              </div>

              {series.image && (
                <div class="overflow-hidden bg-neutral-200">
                  <img
                    src={urlFor(series.image).width(2800).height(1800).fit("crop").url()}
                    alt={series.title}
                    class="aspect-16/10 w-full object-cover transition duration-700 ease-out group-hover:scale-[1.05]"
                  />
                </div>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

    {data.works?.length > 0 && (
      <section>
        <h2 class="mb-8 text-[0.75rem] font-medium uppercase tracking-[0.28em] text-neutral-500 md:mb-10">
          Works
        </h2>     

        <div class={worksGridClass}>
          {data.works.map((work: any) => (
            <a
              href={`/${data.slug}/${work.slug}`}
              class="group block"
            >
               <div class="mt-4 md:mt-5">
                <h3 class="text-2xl leading-tight tracking-tight text-neutral-950 sm:text-3xl md:text-[2rem]">
                  {work.title}
                </h3>
              </div>

              {work.image && (
                <div class="overflow-hidden bg-neutral-200">
                  <img
                    src={urlFor(work.image).width(2800).height(1800).fit("crop").url()}
                    alt={work.image?.alt || work.title}
                    class="aspect-16/10 w-full object-cover transition duration-700 ease-out group-hover:scale-[1.05]"
                  />
                </div>
              )}
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>