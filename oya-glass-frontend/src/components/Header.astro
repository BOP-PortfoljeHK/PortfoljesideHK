---
const currentPath = Astro.url.pathname;
---

<!-- HEADER - som skal ligge øvesrt på alle sidene -->
<header class="fixed top-0 left-0 w-full z-[9999] px-8 py-4 border-b border-gray-300 bg-[#c2b1a4]">

    <div class="w-full px-8">
        <nav class="flex items-center justify-between">

            <!-- Logoen/navnet til eier -->
            <a href="/" class="font-bold text-[1.2rem] text-black no-underline">
            Hanna K
            </a>

            <!-- Hamburgermeny, som kun skal vises på mindre skjermer/monil -->
             <button id="menu-toggle" class="md:hidden flex flex-col justify-center items-center w-8 h-8">
                <span class="line block w-6 h-0.5 bg-black mb-1"></span>
                <span class="line block w-6 h-0.5 bg-black mb-1"></span>
                <span class="line block w-6 h-0.5 bg-black"></span>
             </button>

             <!-- Desktop-meny, som er skjult på mobil -->
            <div class="hidden md:flex space-x-6 ml-auto">

                <!-- WORK med dropdownMeny -->
                <div class="relative group">
                    <a href="/work" class={`text-black font-medium no-underline ${
                        currentPath === "/work" ||
                        currentPath === "/applied-arts" ||
                        currentPath === "/jewelry-collections" ||
                        currentPath === "/sculptural"
                            ? "underline" 
                            : ""
                            }`}>
                        Work
                    </a>

                    <!-- Dropdown, som vises ved hover på work -->
                    <div class="absolute left-0 top-full hidden group-hover:block hover:block bg-[#c2b1a4] text-black px-6 py-4 min-w-[220px] shadow-lg z-[9999]">

                        <a href="/applied-arts"
                        class={`block py-1 ${currentPath === "/applied-arts" ? "underline" : "hover:underline"}`}>
                            Applied arts
                        </a>

                        <a href="/jewelry-collections"
                        class={`block py-1 ${currentPath === "/jewelry-collections" ? "underline" : "hover:underline"}`}>
                            Jewelry collections
                        </a>

                        <a href="/sculptural"
                        class={`block py-1 ${currentPath === "/sculptural" ? "underline" : "hover:underline"}`}>
                            Sculptural
                        </a>
                    </div>
                </div>

                <!-- Vanlige meny-lenker -->
                <a href="/oyaglass" class={`text-black font-medium no-underline ${currentPath === "/oyaglass" ? "underline" : ""}`}>
                    Øya glass studio
                </a>

                <a href="/about" class={`text-black font-medium no-underline ${currentPath === "/about" ? "underline" : ""}`}>
                    About
                </a>

                <a href="/contact" class={`text-black font-medium no-underline ${currentPath === "/contact" ? "underline" : ""}`}>
                    Contact
                </a>
            </div>
        </nav>
    </div>
    
    <!-- MobilMeny - hamburgermeny -->
    <nav id="mobile-menu" class="hidden md:hidden absolute right-8 top-full mt-2 bg-[#c2b1a4] px-6 py-4 shadow-lg">
        <div class="flex flex-col space-y-3">

            <a href="/work" class="text-black no-underline">Work</a>

            <a href="/applied-arts" class="text-black no-underline pl-4">Applied arts</a>
            <a href="/jewelry-collections" class="text-black no-underline pl-4">Jewelry collections</a>
            <a href="/sculptural" class="text-black no-underline pl-4">Sculptural</a>

            <a href="/oyaglass" class="text-black no-underline">Øya glass studio</a>
            <a href="/about" class="text-black no-underline">About</a>
            <a href="/contact" class="text-black no-underline">Contact</a>

        </div>
    </nav>
</header>

<!-- Åpner og lukker mobilmenyen -->
<script>
    const toggleButton = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");

    toggleButton?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");

        /* Lukker meny med kryss */
        const lines = toggleButton.querySelectorAll(".line");

        lines[0].classList.toggle("rotate-45");
        lines[0].classList.toggle("translate-y-1.5");

        lines[1].classList.toggle("opacity-0");

        lines[2].classList.toggle("-rotate-45");
        lines[2].classList.toggle("-translate-y-1.5");
    });
</script>