---
const currentPath = Astro.url.pathname;
const { categories = [] } = Astro.props;
---

<header id="site-header" class="fixed top-0 left-0 w-full z-9999 px-6 py-4 bg-neutral-100/40 backdrop-blur-lg transition-transform duration-300">
  <div class="w-full px-4 pxc-6 md:px-8">
    <nav class="flex items-center justify-between">
      <div class="flex flex-col">
      <a href="/" class="text-[2.3rem] tracking-wide text-black no-underline hover:opacity-70 transition transform hover:scale-105">
        Hanna Karlsen
      </a>
      <p class="text-sm font-bold uppercase tracking-wide text-black/60">
        Glass artist
      </p>
      </div>

      {/* Desktop meny */}
      <button id="menu-toggle" class="md:hidden flex flex-col justify-center items-center w-10 h-10" aria-label="Toggle mobile menu">
        <span class="line block w-6 h-0.5 bg-black mb-1 transition duration-300"></span>
        <span class="line block w-6 h-0.5 bg-black mb-1 transition duration-300"></span>
        <span class="line block w-6 h-0.5 bg-black mb-1 transition duration-300"></span>
      </button>

      {/* Viser dynamisk meny for kategorier, slug-sider */}
      <div class="hidden md:flex items-center space-x-8 ml-auto">
        <div class="relative group">
          <a
            href="/work"
            class={`inline-block text-black no-underline text-base md:text-lg font-medium tracking-wide transition transform hover:opacity-70 hover:scale-105 ${
              currentPath === "/work" ||
              categories.some((category: { slug: any }) => currentPath === `/${category.slug}`)
                ? "underline"
                : ""
            }`}
          >
            Work
          </a>

          <div class="absolute left-0 top-full hidden group-hover:block hover:block bg-neutral-100/98 text-black px-6 py-4 min-w-55 shadow-lg z-9999">
            {categories.map((category: { slug: any; title: unknown }) => (
              <a
                href={`/${category.slug}`}
                class={`block py-1 text-base no-underline transition hover:opacity-70 hover:scale-105 ${
                  currentPath === `/${category.slug}`
                    ? "underline"
                    : "hover:underline"
                }`}
              >
                {category.title}
              </a>
            ))}
          </div>
        </div>

        {/* Statisk meny for "faste sider" */}
        <a
          href="/oyaglass"
          class={`text-black no-underline text-base md:text-lg font-medium tracking-wide transition hover:opacity-70 hover:scale-105 ${
            currentPath === "/oyaglass" ? "underline" : ""
          }`}
        >
          Øya glass studio
        </a>

        <a
          href="/howItsMade"
          class={`text-black no-underline text-base md:text-lg font-medium tracking-wide transition hover:opacity-70 hover:scale-105 ${
            currentPath === "/howItsMade" ? "underline" : ""
          }`}
          >
          How It's Made
        </a>

        <a
          href="/about"
          class={`text-black no-underline text-base md:text-lg font-medium tracking-wide transition hover:opacity-70 hover:scale-105 ${
            currentPath === "/about" ? "underline" : ""
          }`}
        >
          About
        </a>

        <a
          href="/contact"
          class={`text-black no-underline text-base md:text-lg font-medium tracking-wide transition hover:opacity-70 hover:scale-105 ${
            currentPath === "/contact" ? "underline" : ""
          }`}
        >
          Contact
        </a>
      </div>
    </nav>
  </div>


  {/* Mobilmeny */}
 
  <nav id="mobile-menu" class="hidden md:hidden absolute right-4 top-full mt-2 bg-neutral-100/98 px-6 py-4 shadow-lg">
    <div class="flex flex-col space-y-3">
      <a href="/work" class="text-black no-underline hover:underline transition hover:scale-105">Work</a>

      {categories.map((category: { slug: any; title: unknown }) => (
        <a
          href={`/${category.slug}`}
          class="text-black no-underline hover:underline pl-4 transition hover:opacity-70 hover:scale-105"
        >
          {category.title}
        </a>
      ))}

      <a href="/oyaglass" class="text-black no-underline hover:underline transition hover:opacity-70 hover:scale-105">Øya glass studio</a>
      <a href="/howItsMade" class="text-black no-underline hover:underline transition hover:opacity-70 hover:scale-105">How It's Made</a>
      <a href="/about" class="text-black no-underline hover:underline transition hover:opacity-70 hover:scale-105">About</a>
      <a href="/contact" class="text-black no-underline hover:underline transition hover:opacity-70 hover:scale-105">Contact</a>
    </div>
  </nav>
</header>


{/* Script for å toggle mobilmeny, slik at den vises og skjules ved klikk */}
<script>
  const toggleButton = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");

  toggleButton?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");

    const lines = toggleButton.querySelectorAll(".line");

    lines[0].classList.toggle("rotate-45");
    lines[0].classList.toggle("translate-y-1.5");

    lines[1].classList.toggle("opacity-0");

    lines[2].classList.toggle("-rotate-45");
    lines[2].classList.toggle("-translate-y-1.5");
  });

  // Script for å skjule header ved scroll ned og vise den ved scroll opp
  const header = document.getElementById("site-header");

  let lastScrollY = window.scrollY;

  window.addEventListener("scroll", () => {
    const currentScrollY = window.scrollY;

    if (!header) return;

    if (currentScrollY > lastScrollY && currentScrollY > 80) {
      // scroller ned → skjul
      header.style.transform = "translateY(-100%)";
    } else {
      // scroller opp → vis
      header.style.transform = "translateY(0)";
    }

    lastScrollY = currentScrollY;
  });
</script>